{
  "name": "desktop",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "pnpm -w run build-spotify && tsc && electron .",
    "typecheck": "tsc --noEmit",
    "build:check": "tsc --noEmit",
    "package": "pnpm -w run build-spotify && tsc && electron-builder --dir"
  },
  "dependencies": {
    "@showerlist/spotify-client": "workspace:*",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.brunolazaro.showerlist",
    "productName": "ShowerList",
    "mac": {
      "category": "public.app-category.music",
      "target": [{ "target": "dmg", "arch": ["universal"] }]
    },
    "protocols": [
      {
        "name": "ShowerList",
        "schemes": ["showerlist"]
      }
    ],
    "files": ["dist/**/*", "assets/**/*", "!assets/README.md"],
    "extraMetadata": {
      "main": "dist/main/index.js"
    }
  }
}
